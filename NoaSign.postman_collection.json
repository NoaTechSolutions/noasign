                "type": "text/javascript",
                "exec": [
                  "pm.test('documents/types returns 200', function () {",
                  "  pm.response.to.have.status(200);",
                  "});",
                  "const body = pm.response.json();",
                  "pm.test('documents/types returns data', function () {",
                  "  pm.expect(body.length).to.be.greaterThan(0);",
                  "});",
                  "const contractType = body.find((item) => item.formDefinitions?.length && item.pandaTemplates?.length);",
                  "if (contractType) {",
                  "  pm.collectionVariables.set('document_type_id', contractType.id);",
                  "  pm.collectionVariables.set('form_definition_id', contractType.formDefinitions[0].id);",
                  "  pm.collectionVariables.set('pandadoc_template_id', contractType.pandaTemplates[0].id);",
                  "}"
                ]
              }
            }
