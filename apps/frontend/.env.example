NEXT_PUBLIC_API_URL=http://127.0.0.1:3000

# --- Observability (Sentry) ---
# Leave EMPTY in local: the SDK is gated on the DSN, so it stays a no-op.
# Only set these in staging/prod via the deploy — never commit a DSN.
# NEXT_PUBLIC_* is inlined into the browser bundle (the DSN is public by design).
NEXT_PUBLIC_SENTRY_DSN=
# Environment tag for BROWSER errors — must be NEXT_PUBLIC_* to be inlined
# client-side. Set to: development | staging | production.
NEXT_PUBLIC_SENTRY_ENVIRONMENT=
# Optional server-only overrides (Next server/edge runtimes). If unset, the
# server falls back to NEXT_PUBLIC_SENTRY_DSN / NEXT_PUBLIC_SENTRY_ENVIRONMENT.
SENTRY_DSN=
SENTRY_ENVIRONMENT=
