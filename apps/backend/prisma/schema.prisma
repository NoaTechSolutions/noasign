generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  MASTER
  ADMIN
  USER
}

enum UserStatus {
  ACTIVE
  INACTIVE
  SUSPENDED
}

enum AccountRequestStatus {
  PENDING
  APPROVED
  REJECTED
}

enum AccountType {
  INDIVIDUAL
  BUSINESS
}

enum CustomerType {
  PERSONAL
  BUSINESS
}

enum DocumentStatus {
  DRAFT
  SENT
  VIEWED
  SIGNED
  COMPLETED
  CANCELLED
}

enum DocumentFileType {
  PREVIEW
  SIGNED_PDF
  ATTACHMENT
}

enum StorageProvider {
  BOLDSIGN
  S3
  R2
}

enum PlanName {
  LAUNCH
  SCALE
  PRO_UNLIMITED
}

model CompanyProfile {
  id                    String  @id @default(uuid())
  companyName           String
  legalName             String?
  industry              String?
  website               String?
  email                 String?
  phone                 String?
  phone2                String?
  insuranceName         String?
  insurancePhone        String?
  insurancePolicyNumber String?
  addressLine1          String?
  addressLine2          String?
  city                  String?
  state                 String?
  zipCode               String?
  country               String?
  logoUrl               String?
  licenseNumber         String?

  contactFirstName    String?
  contactLastName     String?
  contactTitle        String?
  contactEmail        String?
  contactPhone        String?
  contactAddressLine1 String?
  contactAddressLine2 String?
  contactCity         String?
  contactState        String?
  contactZipCode      String?
  contactCountry      String?

  planName        PlanName @default(LAUNCH)
  monthlyDocLimit Int      @default(5)
  overagePrice    Decimal  @default(5.00) @db.Decimal(10, 2)
  isUnlimited     Boolean  @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  users     User[]
  documents Document[]
  customers Customer[]

  @@map("company_profiles")
}

model User {
  id                     String       @id @default(uuid())
  companyProfileId       String?
  parentCompanyProfileId String?
  email                  String       @unique
  passwordHash           String
  mustChangePassword     Boolean      @default(false)
  role                   UserRole
  status                 UserStatus   @default(ACTIVE)
  accountType            AccountType?
  firstName              String?
  lastName               String?
  title                  String?
  phone                  String?
  addressLine1           String?
  addressLine2           String?
  city                   String?
  state                  String?
  zipCode                String?
  avatarUrl              String?

  // Auth security. failedLoginAttempts resets to 0 on successful login OR when
  // a lockout is triggered (lockedUntil becomes the source of truth for
  // "blocked"). lockedUntil is forward-only: while > now() the account refuses
  // login with ACCOUNT_LOCKED. lastLoginAt is set only on successful login.
  failedLoginAttempts Int       @default(0)
  lockedUntil         DateTime?
  lastLoginAt         DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  companyProfile      CompanyProfile?      @relation(fields: [companyProfileId], references: [id], onDelete: SetNull)
  documentConfigs     UserDocumentConfig[]
  documents           Document[]
  documentVersions    DocumentVersion[]
  passwordResetTokens PasswordResetToken[]
  createdCustomers    Customer[] @relation("CustomerCreatedBy")
  ownedCustomers      Customer[] @relation("CustomerOwner")

  @@index([companyProfileId])
  @@index([parentCompanyProfileId])
  @@map("users")
}

model PasswordResetToken {
  id        String    @id @default(uuid())
  userId    String
  tokenHash String    @unique
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiresAt])
  @@map("password_reset_tokens")
}

// Append-only log of MASTER actions. actorId and targetUserId are stored as
// raw IDs (no FK) so audit history survives if either user is later deleted —
// retention beats referential cleanliness for this table. `action` is a
// SCREAMING_SNAKE_CASE verb-object string ("UNLOCK_USER", future verbs added
// without a migration). `payload` captures pre-action state for review.
model AdminAuditLog {
  id           String   @id @default(uuid())
  actorId      String
  action       String
  targetUserId String?
  payload      Json?
  createdAt    DateTime @default(now())

  @@index([actorId])
  @@index([targetUserId])
  @@index([createdAt])
  @@map("admin_audit_logs")
}

model Customer {
  id               String       @id @default(uuid())
  companyProfileId String
  // Current owner — only this user (and tenant masters) can see/edit. Used
  // for per-user tenant isolation. Distinct from createdByUserId, which is
  // an immutable audit field.
  userId           String
  createdByUserId  String?
  customerType     CustomerType @default(PERSONAL)

  fullName String
  email    String?
  phone    String?

  addressLine1 String?
  addressLine2 String?
  city         String?
  state        String?
  zipCode      String?
  country      String?

  notes String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  companyProfile CompanyProfile    @relation(fields: [companyProfileId], references: [id], onDelete: Cascade)
  user           User              @relation("CustomerOwner", fields: [userId], references: [id], onDelete: Restrict)
  createdBy      User?             @relation("CustomerCreatedBy", fields: [createdByUserId], references: [id], onDelete: SetNull)
  business       CustomerBusiness?
  documents      Document[]

  @@index([companyProfileId])
  @@index([companyProfileId, fullName])
  @@index([companyProfileId, email])
  @@index([companyProfileId, customerType])
  @@index([companyProfileId, userId])
  @@index([userId])
  @@map("customers")
}

model CustomerBusiness {
  id         String @id @default(uuid())
  customerId String @unique

  // Business Info
  businessName      String
  businessLegalName String?
  licenseNumber     String?
  industry          String?
  website           String?
  businessEmail     String?
  businessPhone     String?

  // Business Contact / Address
  businessPhone2       String?
  businessAddressLine1 String?
  businessAddressLine2 String?
  businessCity         String?
  businessState        String?
  businessZipCode      String?

  // Primary Contact
  primaryContactName        String?
  primaryContactEmail       String?
  primaryContactPhone       String?
  primaryContactTitle       String?
  primaryContactAddressLine1 String?
  primaryContactCity        String?
  primaryContactState       String?
  primaryContactZipCode     String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  customer Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)

  @@map("customer_businesses")
}

model AccountRequest {
  id                     String               @id @default(uuid())
  fullName               String
  email                  String               @unique
  requestedDocumentTypes Json
  status                 AccountRequestStatus @default(PENDING)
  processedAt            DateTime?
  createdAt              DateTime             @default(now())
  updatedAt              DateTime             @updatedAt

  @@index([status])
  @@index([createdAt])
  @@map("account_requests")
}

model DocumentType {
  id   String @id @default(uuid())
  name String @unique
  code String @unique

  formDefinitions    FormDefinition[]
  signatureTemplates SignatureTemplate[]
  userConfigs        UserDocumentConfig[]
  documents          Document[]

  @@map("document_types")
}

model FormDefinition {
  id             String   @id @default(uuid())
  name           String
  documentTypeId String
  schemaJson     Json?
  description    String?
  isActive       Boolean  @default(true)
  createdAt      DateTime @default(now())

  documentType DocumentType         @relation(fields: [documentTypeId], references: [id], onDelete: Restrict)
  userConfigs  UserDocumentConfig[]
  documents    Document[]

  @@index([documentTypeId])
  @@map("form_definitions")
}

model SignatureTemplate {
  id                  String   @id @default(uuid())
  name                String
  documentTypeId      String
  providerTemplateId  String
  recipientRole       String   @default("Client")
  tokenMappingJson    Json?
  fieldMappingJson    Json?
  sendSubjectTemplate String?
  sendMessageTemplate String?
  isActive            Boolean  @default(true)
  createdAt           DateTime @default(now())

  documentType DocumentType         @relation(fields: [documentTypeId], references: [id], onDelete: Restrict)
  userConfigs  UserDocumentConfig[]
  documents    Document[]

  @@index([documentTypeId])
  @@map("signature_templates")
}

model UserDocumentConfig {
  id                  String   @id @default(uuid())
  userId              String
  documentTypeId      String
  formDefinitionId    String
  signatureTemplateId String
  isActive            Boolean  @default(true)
  createdAt           DateTime @default(now())

  user              User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  documentType      DocumentType      @relation(fields: [documentTypeId], references: [id], onDelete: Restrict)
  formDefinition    FormDefinition    @relation(fields: [formDefinitionId], references: [id], onDelete: Restrict)
  signatureTemplate SignatureTemplate @relation(fields: [signatureTemplateId], references: [id], onDelete: Restrict)

  @@unique([userId, documentTypeId, formDefinitionId, signatureTemplateId])
  @@index([userId])
  @@index([documentTypeId])
  @@map("user_document_configs")
}

model Document {
  id                   String         @id @default(uuid())
  documentNumber       String         @unique
  userId               String
  companyProfileId     String?
  customerId           String?
  documentTypeId       String
  formDefinitionId     String
  signatureTemplateId  String
  providerDocumentId   String?
  providerStatus       String?
  providerLastSyncedAt DateTime?
  status               DocumentStatus

  contractDate           DateTime?
  sentAt                 DateTime?
  viewedAt               DateTime?
  signedAt               DateTime?
  completedAt            DateTime?
  cancelledAt            DateTime?
  lastManualReminderAt   DateTime?
  lastSentRecipientEmail String?

  countedInBilling Boolean @default(false)
  isOverage        Boolean @default(false)
  billingPeriod    String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user              User              @relation(fields: [userId], references: [id], onDelete: Restrict)
  companyProfile    CompanyProfile?   @relation(fields: [companyProfileId], references: [id], onDelete: SetNull)
  customer          Customer?         @relation(fields: [customerId], references: [id], onDelete: SetNull)
  documentType      DocumentType      @relation(fields: [documentTypeId], references: [id], onDelete: Restrict)
  formDefinition    FormDefinition    @relation(fields: [formDefinitionId], references: [id], onDelete: Restrict)
  signatureTemplate SignatureTemplate @relation(fields: [signatureTemplateId], references: [id], onDelete: Restrict)
  data              DocumentData?
  versions          DocumentVersion[]
  files             DocumentFile[]

  @@index([userId])
  @@index([companyProfileId])
  @@index([customerId])
  @@index([documentTypeId])
  @@index([status])
  @@index([createdAt])
  @@index([providerDocumentId])
  @@map("documents")
}

model DocumentData {
  id         String   @id @default(uuid())
  documentId String   @unique
  dataJson   Json
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  document Document @relation(fields: [documentId], references: [id], onDelete: Cascade)

  @@map("document_data")
}

model DocumentVersion {
  id              String   @id @default(uuid())
  documentId      String
  versionNumber   Int
  snapshotJson    Json
  changedByUserId String?
  createdAt       DateTime @default(now())

  document      Document @relation(fields: [documentId], references: [id], onDelete: Cascade)
  changedByUser User?    @relation(fields: [changedByUserId], references: [id], onDelete: SetNull)

  @@unique([documentId, versionNumber])
  @@index([documentId])
  @@map("document_versions")
}

model DocumentFile {
  id         String           @id @default(uuid())
  documentId String
  fileType   DocumentFileType
  provider   StorageProvider
  storageUrl String
  fileName   String?
  mimeType   String?
  createdAt  DateTime         @default(now())

  document Document @relation(fields: [documentId], references: [id], onDelete: Cascade)

  @@index([documentId])
  @@map("document_files")
}
