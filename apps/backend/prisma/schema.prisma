generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  SUPERADMIN
  USER
}

enum UserStatus {
  ACTIVE
  INACTIVE
  SUSPENDED
}

enum AccountRequestStatus {
  PENDING
  APPROVED
  REJECTED
}

enum AccountType {
  INDIVIDUAL
  BUSINESS
}

enum CustomerType {
  PERSONAL
  BUSINESS
}

enum CustomerStatus {
  ACTIVE
  INACTIVE
  DELETED
}

enum DocumentStatus {
  DRAFT
  SENT
  SEND_FAILED
  VIEWED
  SIGNED
  COMPLETED
  CANCELLED
}

enum DocumentFileType {
  PREVIEW
  SIGNED_PDF
  ATTACHMENT
  // Generated payment-receipt PDF persisted to R2 (DIRECT_PDF docs).
  RECEIPT
}

enum GenerationMode {
  BOLDSIGN
  DIRECT_PDF
}

enum StorageProvider {
  BOLDSIGN
  S3
  R2
}

enum PlanName {
  LAUNCH
  SCALE
  PRO_UNLIMITED
  // Model C (additive — legacy values above are intentionally NOT remapped):
  STARTER
  PRO
  PAY_PER_CONTRACT
  RECEIPTS_ONLY
}

// Template feature: document categories with different backing engines.
// RECEIPT = DIRECT_PDF (base PDF + coordinates). CONTRACT = BoldSign template.
// INVOICE = DIRECT_PDF via AcroForm fill (base PDF + named form fields).
enum TemplateCategory {
  RECEIPT
  CONTRACT
  INVOICE
}

model CompanyProfile {
  id                    String  @id @default(uuid())
  companyName           String
  legalName             String?
  industry              String?
  website               String?
  email                 String?
  phone                 String?
  phone2                String?
  insuranceName         String?
  insurancePhone        String?
  insurancePolicyNumber String?
  insuranceExpiryDate   DateTime? @db.Date
  addressLine1          String?
  addressLine2          String?
  city                  String?
  state                 String?
  zipCode               String?
  country               String?
  logoUrl               String?
  licenseNumber         String?

  contactFirstName    String?
  contactLastName     String?
  contactTitle        String?
  contactEmail        String?
  contactPhone        String?
  contactAddressLine1 String?
  contactAddressLine2 String?
  contactCity         String?
  contactState        String?
  contactZipCode      String?
  contactCountry      String?

  planName        PlanName @default(LAUNCH)
  monthlyDocLimit Int      @default(5)
  // Aligned to the default plan's (LAUNCH) canonical contract overage. The old
  // $5.00 matched no plan and leaked into tenants created without an explicit
  // value. New tenants/plan assignments seed this from PLAN_DEFAULTS.
  overagePrice    Decimal  @default(3.50) @db.Decimal(10, 2)
  isUnlimited     Boolean  @default(false)

  // Model C — per-tenant receipt billing (separate from contract limits above).
  // Seeded from PLAN_DEFAULTS when a plan is assigned; enforcement reads these
  // fields directly so manual overrides survive.
  monthlyReceiptLimit Int     @default(0)
  receiptsUnlimited   Boolean @default(false)
  receiptOveragePrice Decimal @default(0.25) @db.Decimal(10, 2)
  contractsEnabled    Boolean @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  users              User[]
  documents          Document[]
  customers          Customer[]
  receiptTemplates   ReceiptTemplate[]
  receiptCounters    ReceiptCounter[]
  // Custom (per-tenant) contract templates — global standards have a null FK.
  signatureTemplates SignatureTemplate[]
  // Templates this tenant is eligible for (default/active per category).
  companyTemplates   CompanyTemplate[]
  // Generic per-(type, year) visible-series counters (REC-/INV-…).
  documentSeriesCounters DocumentSeriesCounter[]

  @@map("company_profiles")
}

model User {
  id                     String       @id @default(uuid())
  companyProfileId       String?
  parentCompanyProfileId String?
  email                  String       @unique
  passwordHash           String
  mustChangePassword     Boolean      @default(false)
  role                   UserRole
  status                 UserStatus   @default(ACTIVE)
  accountType            AccountType?
  firstName              String?
  lastName               String?
  title                  String?
  phone                  String?
  addressLine1           String?
  addressLine2           String?
  city                   String?
  state                  String?
  zipCode                String?
  avatarUrl              String?

  failedLoginAttempts Int       @default(0)
  lockLevel           Int       @default(0)
  lockedUntil         DateTime?
  lastLoginAt         DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  companyProfile      CompanyProfile?      @relation(fields: [companyProfileId], references: [id], onDelete: SetNull)
  documentConfigs     UserDocumentConfig[]
  documents           Document[]
  documentVersions    DocumentVersion[]
  documentSequences   UserDocumentSequence[]
  passwordResetTokens PasswordResetToken[]
  createdCustomers    Customer[] @relation("CustomerCreatedBy")
  ownedCustomers      Customer[] @relation("CustomerOwner")

  @@index([companyProfileId])
  @@index([parentCompanyProfileId])
  @@map("users")
}

model PasswordResetToken {
  id        String    @id @default(uuid())
  userId    String
  tokenHash String    @unique
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiresAt])
  @@map("password_reset_tokens")
}

// Append-only log of MASTER actions. actorId and targetUserId are stored as
// raw IDs (no FK) so audit history survives if either user is later deleted —
// retention beats referential cleanliness for this table. `action` is a
// SCREAMING_SNAKE_CASE verb-object string ("UNLOCK_USER", future verbs added
// without a migration). `payload` captures pre-action state for review.
model AdminAuditLog {
  id           String   @id @default(uuid())
  actorId      String
  action       String
  targetUserId String?
  payload      Json?
  createdAt    DateTime @default(now())

  @@index([actorId])
  @@index([targetUserId])
  @@index([createdAt])
  @@map("admin_audit_logs")
}

model Customer {
  id               String       @id @default(uuid())
  companyProfileId String
  // Current owner — only this user (and tenant masters) can see/edit. Used
  // for per-user tenant isolation. Distinct from createdByUserId, which is
  // an immutable audit field.
  userId           String
  createdByUserId  String?
  customerType     CustomerType   @default(PERSONAL)
  status           CustomerStatus @default(ACTIVE)
  // Soft delete — null = active, timestamp = deleted (restorable by MASTER).
  deletedAt        DateTime?

  fullName String
  email    String?
  phone    String?

  addressLine1 String?
  addressLine2 String?
  city         String?
  state        String?
  zipCode      String?
  country      String?

  notes String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  companyProfile CompanyProfile    @relation(fields: [companyProfileId], references: [id], onDelete: Cascade)
  user           User              @relation("CustomerOwner", fields: [userId], references: [id], onDelete: Restrict)
  createdBy      User?             @relation("CustomerCreatedBy", fields: [createdByUserId], references: [id], onDelete: SetNull)
  business       CustomerBusiness?
  documents      Document[]

  @@index([companyProfileId])
  @@index([companyProfileId, fullName])
  @@index([companyProfileId, email])
  @@index([companyProfileId, customerType])
  @@index([companyProfileId, status])
  @@index([companyProfileId, deletedAt])
  @@index([companyProfileId, userId])
  @@index([userId])
  @@map("customers")
}

model CustomerBusiness {
  id         String @id @default(uuid())
  customerId String @unique

  // Business Info
  businessName      String
  businessLegalName String?
  licenseNumber     String?
  industry          String?
  website           String?
  businessEmail     String?
  businessPhone     String?

  // Business Contact / Address
  businessPhone2       String?
  businessAddressLine1 String?
  businessAddressLine2 String?
  businessCity         String?
  businessState        String?
  businessZipCode      String?

  // Primary Contact
  primaryContactName        String?
  primaryContactEmail       String?
  primaryContactPhone       String?
  primaryContactTitle       String?
  primaryContactAddressLine1 String?
  primaryContactCity        String?
  primaryContactState       String?
  primaryContactZipCode     String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  customer Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)

  @@map("customer_businesses")
}

model AccountRequest {
  id                     String               @id @default(uuid())
  fullName               String
  email                  String               @unique
  requestedDocumentTypes Json
  status                 AccountRequestStatus @default(PENDING)
  processedAt            DateTime?
  createdAt              DateTime             @default(now())
  updatedAt              DateTime             @updatedAt

  @@index([status])
  @@index([createdAt])
  @@map("account_requests")
}

// Soft marketing leads (e.g. the email captured on the post-signature confirmation
// page). Distinct from AccountRequest (a hard "create my account" request) and the
// email-only contact form — this is a queryable list for follow-up. No auth: it's
// submitted by external signers.
model Lead {
  id        String   @id @default(uuid())
  email     String
  // Optional follow-up details captured in step 2 of the lead flow (the signer
  // can submit just the email and bail, so both stay nullable).
  name      String?
  phone     String?
  // Where the lead came from, so future capture points stay queryable apart.
  source    String   @default("signature-complete")
  createdAt DateTime @default(now())

  @@index([createdAt])
  @@map("leads")
}

model DocumentType {
  id   String @id @default(uuid())
  name String @unique
  code String @unique

  // BOLDSIGN: signed via BoldSign. DIRECT_PDF: generated + emailed directly
  // (receipts) using a ReceiptTemplate — no signature flow.
  generationMode GenerationMode @default(BOLDSIGN)

  formDefinitions          FormDefinition[]
  signatureTemplates       SignatureTemplate[]
  userConfigs              UserDocumentConfig[]
  documents                Document[]
  // Generic DIRECT_PDF templates keyed by this type (receipts today; invoices next).
  receiptTemplates         ReceiptTemplate[]
  receiptTemplateStandards ReceiptTemplateStandard[]
  documentSeriesCounters   DocumentSeriesCounter[]
  userDocumentSequences    UserDocumentSequence[]

  @@map("document_types")
}

model FormDefinition {
  id             String   @id @default(uuid())
  name           String
  documentTypeId String
  schemaJson     Json?
  description    String?
  isActive       Boolean  @default(true)
  createdAt      DateTime @default(now())

  documentType DocumentType         @relation(fields: [documentTypeId], references: [id], onDelete: Restrict)
  userConfigs  UserDocumentConfig[]
  documents    Document[]

  @@index([documentTypeId])
  @@map("form_definitions")
}

model SignatureTemplate {
  id                  String   @id @default(uuid())
  name                String
  documentTypeId      String
  providerTemplateId  String
  recipientRole       String   @default("Client")
  tokenMappingJson    Json?
  fieldMappingJson    Json?
  sendSubjectTemplate String?
  sendMessageTemplate String?
  isActive            Boolean  @default(true)
  // Template feature (additive): a null companyProfileId = a GLOBAL standard
  // template (shared catalog); a set value = a CUSTOM template owned by that
  // tenant. isStandard marks the curated global catalog; slug is its stable id;
  // isDefault marks the default standard within the CONTRACT category.
  companyProfileId    String?
  isStandard          Boolean  @default(false)
  slug                String?  @unique
  isDefault           Boolean  @default(false)
  createdAt           DateTime @default(now())

  documentType     DocumentType         @relation(fields: [documentTypeId], references: [id], onDelete: Restrict)
  companyProfile   CompanyProfile?      @relation(fields: [companyProfileId], references: [id], onDelete: SetNull)
  userConfigs      UserDocumentConfig[]
  documents        Document[]
  companyTemplates CompanyTemplate[]

  @@index([documentTypeId])
  @@index([companyProfileId])
  @@map("signature_templates")
}

// Template-driven receipt generation (DIRECT_PDF). Base PDF + field coordinates
// live here, not in code — a new client is a new row, not a code change.
model ReceiptTemplate {
  id               String   @id @default(cuid())
  companyProfileId String
  name             String
  basePdfPath      String
  pageWidth        Float    @default(612)
  pageHeight       Float    @default(792)
  mediaBoxOffsetY  Float    @default(0)
  fieldMappingJson Json
  numberFormat     String   @default("REC-{YYYY}-{NNNN}")
  isActive         Boolean  @default(true)
  // Template feature (additive): standardId links this per-tenant instance back
  // to the global catalog design it was provisioned from (null = fully custom).
  // isDefault marks the tenant's default receipt template (multi-template ready).
  standardId       String?
  isDefault        Boolean  @default(false)
  // Decision A — generalize: this is a generic DIRECT_PDF template, not
  // receipt-specific. category/documentTypeId scope it to a document type
  // (RECEIPT today, INVOICE next). The receipt_* table name is legacy only.
  category         TemplateCategory?
  documentTypeId   String?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  companyProfile   CompanyProfile           @relation(fields: [companyProfileId], references: [id], onDelete: Cascade)
  standard         ReceiptTemplateStandard? @relation(fields: [standardId], references: [id], onDelete: SetNull)
  documentType     DocumentType?            @relation(fields: [documentTypeId], references: [id], onDelete: Restrict)
  documents        Document[]
  companyTemplates CompanyTemplate[]

  @@index([companyProfileId])
  @@index([standardId])
  @@index([documentTypeId])
  @@map("receipt_templates")
}

// Global catalog of STANDARD receipt designs (base PDF + coordinates), shared
// across tenants. Decision 1: a single source of truth instead of replicating a
// design row per tenant. A tenant gets a concrete per-tenant ReceiptTemplate
// instance provisioned FROM one of these (see ReceiptTemplate.standardId), which
// is what the PDF engine consumes today — this catalog is the design source.
model ReceiptTemplateStandard {
  id               String   @id @default(cuid())
  slug             String   @unique
  name             String
  description      String?
  basePdfPath      String
  pageWidth        Float    @default(612)
  pageHeight       Float    @default(792)
  mediaBoxOffsetY  Float    @default(0)
  fieldMappingJson Json
  numberFormat     String   @default("REC-{YYYY}-{NNNN}")
  // How the PDF engine renders this template:
  //   "overlay"  = stamp text at absolute coordinates over the base PDF (receipts).
  //   "acroform" = fill named AcroForm fields on the base PDF, then flatten (invoices).
  // For "acroform", fieldMappingJson maps dataKey -> { field, size, color, ... }.
  renderMode       String   @default("overlay")
  isActive         Boolean  @default(true)
  // Default standard within its category (used by onboarding when no explicit
  // standard is chosen).
  isDefault        Boolean  @default(false)
  // Decision A — generalize: a generic DIRECT_PDF standard, scoped by category /
  // document type (RECEIPT today, INVOICE next). The receipt_* name is legacy.
  category         TemplateCategory?
  documentTypeId   String?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  instances        ReceiptTemplate[]
  companyTemplates CompanyTemplate[]
  documentType     DocumentType?     @relation(fields: [documentTypeId], references: [id], onDelete: Restrict)

  @@index([documentTypeId])
  @@map("receipt_template_standards")
}

// Tenant <-> template eligibility. One row per (tenant, template) the tenant may
// use; isDefault marks the active/default one for that category. Supports one or
// many templates per category (multi-template ready). Exactly one source ref is
// set per row (validated in application code), matching the category.
model CompanyTemplate {
  id                  String           @id @default(cuid())
  companyProfileId    String
  category            TemplateCategory
  receiptStandardId   String?
  receiptTemplateId   String?
  signatureTemplateId String?
  isDefault           Boolean          @default(false)
  isActive            Boolean          @default(true)
  createdAt           DateTime         @default(now())
  updatedAt           DateTime         @updatedAt

  companyProfile    CompanyProfile           @relation(fields: [companyProfileId], references: [id], onDelete: Cascade)
  receiptStandard   ReceiptTemplateStandard? @relation(fields: [receiptStandardId], references: [id], onDelete: Cascade)
  receiptTemplate   ReceiptTemplate?         @relation(fields: [receiptTemplateId], references: [id], onDelete: Cascade)
  signatureTemplate SignatureTemplate?       @relation(fields: [signatureTemplateId], references: [id], onDelete: Cascade)

  @@index([companyProfileId, category])
  @@index([receiptStandardId])
  @@index([receiptTemplateId])
  @@index([signatureTemplateId])
  @@map("company_templates")
}

// Per-tenant, per-year correlative counter (resets each year via the unique key).
model ReceiptCounter {
  id               String @id @default(cuid())
  companyProfileId String
  year             Int
  lastNumber       Int    @default(0)

  companyProfile CompanyProfile @relation(fields: [companyProfileId], references: [id], onDelete: Cascade)

  @@unique([companyProfileId, year])
  @@map("receipt_counters")
}

// Generic visible-series counter: per tenant, per document type, per year
// (REC-2026-0001, INV-2026-0001, …). Generalizes ReceiptCounter (kept as a frozen
// legacy table after backfill). Atomic increment via upsert. Resets each year.
model DocumentSeriesCounter {
  id               String @id @default(cuid())
  companyProfileId String
  documentTypeId   String
  year             Int
  lastNumber       Int    @default(0)

  companyProfile CompanyProfile @relation(fields: [companyProfileId], references: [id], onDelete: Cascade)
  documentType   DocumentType   @relation(fields: [documentTypeId], references: [id], onDelete: Cascade)

  @@unique([companyProfileId, documentTypeId, year])
  @@index([companyProfileId])
  @@index([documentTypeId])
  @@map("document_series_counters")
}

// Per-(user, documentType) atomic sequence for the INTERNAL document number
// ({code}-000001, per-user lifetime, no yearly reset). Replaces an O(n)
// max-in-memory scan that also raced under concurrency against the composite
// unique on Document. Backfilled from existing documents (migration 20260706150000).
model UserDocumentSequence {
  id             String @id @default(cuid())
  userId         String
  documentTypeId String
  lastNumber     Int    @default(0)

  user         User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  documentType DocumentType @relation(fields: [documentTypeId], references: [id], onDelete: Cascade)

  @@unique([userId, documentTypeId])
  @@index([userId])
  @@index([documentTypeId])
  @@map("user_document_sequences")
}

model UserDocumentConfig {
  id                  String   @id @default(uuid())
  userId              String
  documentTypeId      String
  formDefinitionId    String
  signatureTemplateId String
  isActive            Boolean  @default(true)
  createdAt           DateTime @default(now())

  user              User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  documentType      DocumentType      @relation(fields: [documentTypeId], references: [id], onDelete: Restrict)
  formDefinition    FormDefinition    @relation(fields: [formDefinitionId], references: [id], onDelete: Restrict)
  signatureTemplate SignatureTemplate @relation(fields: [signatureTemplateId], references: [id], onDelete: Restrict)

  @@unique([userId, documentTypeId, formDefinitionId, signatureTemplateId])
  @@index([userId])
  @@index([documentTypeId])
  @@map("user_document_configs")
}

model Document {
  id                   String         @id @default(uuid())
  // Correlativo scoped PER USER (not global, not per tenant): the visible number
  // restarts at 000001 for each user. Uniqueness is enforced by the composite
  // @@unique([userId, documentTypeId, documentNumber]) below.
  documentNumber       String
  userId               String
  companyProfileId     String?
  customerId           String?
  documentTypeId       String
  formDefinitionId     String
  // Nullable: DIRECT_PDF docs (receipts) have no BoldSign template; they use
  // receiptTemplateId instead. Gated by documentType.generationMode.
  signatureTemplateId  String?
  receiptTemplateId    String?
  providerDocumentId   String?
  providerStatus       String?
  providerLastSyncedAt DateTime?
  status               DocumentStatus

  contractDate           DateTime?
  sentAt                 DateTime?
  viewedAt               DateTime?
  signedAt               DateTime?
  completedAt            DateTime?
  cancelledAt            DateTime?
  lastManualReminderAt   DateTime?
  lastSentRecipientEmail String?

  // Send-outcome tracking (FASE 1: honest send state).
  // sendError: human-readable reason when status is SEND_FAILED.
  // providerEmailId: Resend message id of the last successful send — kept so
  // FASE 2 (bounce webhooks) can correlate the document with the delivery.
  sendError       String?
  providerEmailId String?
  // Last time a receipt's data was edited (DRAFT/SEND_FAILED) — drives the
  // "Edited" entry in the receipt timeline. Not used for contracts.
  lastEditedAt    DateTime?
  // Receipt resend policy v2 (sliding window + hard cap, per recipient email).
  // sendCount: total email ATTEMPTS (SENT or SEND_FAILED) to the current
  //   recipient; reset to 0 when the recipient email changes.
  // lastAttemptAt: timestamp of the last attempt (success OR failure) — drives
  //   the 10-minute window. Not used for contracts.
  sendCount       Int       @default(0)
  lastAttemptAt   DateTime?

  // Receipt reissue (2c): a SENT receipt is never edited; a correction creates a
  // NEW receipt that supersedes the original. supersedesId points from the new
  // receipt to the original; supersededAt marks the original as voided (its
  // status stays SENT — the accounting truth is preserved). "Reissued by" is the
  // back-relation supersededBy.
  supersedesId    String?
  supersededAt    DateTime?

  countedInBilling Boolean @default(false)
  isOverage        Boolean @default(false)
  billingPeriod    String?

  // Model C — receipt billing dimension, separate from countedInBilling so the
  // contract and receipt quotas never cross-contaminate. Reuses billingPeriod.
  // Set on the first successful SEND of a non-reissue receipt (decisions B + C).
  countedAsReceipt Boolean @default(false)
  isReceiptOverage Boolean @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user              User              @relation(fields: [userId], references: [id], onDelete: Restrict)
  companyProfile    CompanyProfile?   @relation(fields: [companyProfileId], references: [id], onDelete: SetNull)
  customer          Customer?         @relation(fields: [customerId], references: [id], onDelete: SetNull)
  documentType      DocumentType       @relation(fields: [documentTypeId], references: [id], onDelete: Restrict)
  formDefinition    FormDefinition     @relation(fields: [formDefinitionId], references: [id], onDelete: Restrict)
  signatureTemplate SignatureTemplate? @relation(fields: [signatureTemplateId], references: [id], onDelete: Restrict)
  receiptTemplate   ReceiptTemplate?   @relation(fields: [receiptTemplateId], references: [id], onDelete: Restrict)
  data              DocumentData?
  versions          DocumentVersion[]
  files             DocumentFile[]
  supersedes        Document?  @relation("ReceiptReissue", fields: [supersedesId], references: [id], onDelete: SetNull)
  supersededBy      Document[] @relation("ReceiptReissue")

  @@index([userId])
  @@index([companyProfileId])
  @@index([customerId])
  @@index([documentTypeId])
  @@index([status])
  @@index([createdAt])
  @@index([providerDocumentId])
  // FASE 2: bounce webhooks look up the document by the Resend message id.
  @@index([providerEmailId])
  @@index([supersedesId])
  // Per-user correlativo: the same number can exist across users, but is unique
  // within (user, type). Replaces the old global @unique on documentNumber.
  @@unique([userId, documentTypeId, documentNumber])
  @@map("documents")
}

model DocumentData {
  id         String   @id @default(uuid())
  documentId String   @unique
  dataJson   Json
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  document Document @relation(fields: [documentId], references: [id], onDelete: Cascade)

  @@map("document_data")
}

model DocumentVersion {
  id              String   @id @default(uuid())
  documentId      String
  versionNumber   Int
  snapshotJson    Json
  changedByUserId String?
  createdAt       DateTime @default(now())

  document      Document @relation(fields: [documentId], references: [id], onDelete: Cascade)
  changedByUser User?    @relation(fields: [changedByUserId], references: [id], onDelete: SetNull)

  @@unique([documentId, versionNumber])
  @@index([documentId])
  @@map("document_versions")
}

model DocumentFile {
  id         String           @id @default(uuid())
  documentId String
  fileType   DocumentFileType
  provider   StorageProvider
  storageUrl String
  fileName   String?
  mimeType   String?
  createdAt  DateTime         @default(now())

  document Document @relation(fields: [documentId], references: [id], onDelete: Cascade)

  @@index([documentId])
  @@map("document_files")
}
