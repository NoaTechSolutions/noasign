DATABASE_URL=postgresql://postgres:postgres@localhost:5432/noasign
JWT_SECRET=replace-with-a-strong-secret
JWT_EXPIRES_IN=86400
AUTH_COOKIE_DOMAIN=
PORT=3000
HOST=0.0.0.0
TRUST_PROXY=1
CORS_ORIGINS=http://127.0.0.1:3001,http://localhost:3001
AUTH_RATE_LIMIT_WINDOW_MS=900000
AUTH_RATE_LIMIT_MAX=10
APP_URL=https://app.example.com
BACKEND_URL=https://api.example.com
SIGNATURE_PROVIDER=boldsign
BOLDSIGN_API_KEY=replace-with-boldsign-api-key
BOLDSIGN_BASE_URL=https://api.boldsign.com
BOLDSIGN_WEBHOOK_SECRET=
BOLDSIGN_CALLBACK_URL=
BOLDSIGN_BRAND_ID=
LOCAL_SIGNATURE_TEMPLATE_ID=replace-with-local-signature-template-id
LOCAL_SIGNATURE_RECIPIENT_ROLE=BUYER

# --- Observability (Sentry) ---
# Leave SENTRY_DSN EMPTY in local: the SDK becomes a no-op (zero impact). Only
# set it in staging/prod via the deploy's secret store — never commit a DSN.
SENTRY_DSN=
# One Sentry project per app + an environment tag so staging and prod never mix.
# Set to: development | staging | production. Falls back to NODE_ENV if empty.
SENTRY_ENVIRONMENT=
# Optional: overrides the release tag. Defaults to package.json version when run
# via an npm script.
SENTRY_RELEASE=
